# FranceTravail API credentials (required)
# Register at https://francetravail.io to get these
FRANCE_TRAVAIL_CLIENT_ID=your_client_id_here
FRANCE_TRAVAIL_CLIENT_SECRET=your_client_secret_here

# Search defaults (optional)
DEFAULT_KEYWORDS=ingénieur télécom
DEFAULT_LOCATION=75
DEFAULT_MAX_RESULTS=50

# Salary filter (optional)
SALARY_MIN=40000
REQUIRE_SALARY=false
